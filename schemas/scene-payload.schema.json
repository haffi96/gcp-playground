{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gcp-playground.local/schemas/scene-payload.schema.json",
  "title": "RacingSimulationScene",
  "type": "object",
  "required": [
    "schemaVersion",
    "timestamp",
    "sceneId",
    "frameId",
    "track",
    "occupancyGrid",
    "vehicles",
    "roadObjects"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "description": "Unix epoch timestamp in milliseconds encoded as string."
    },
    "sceneId": {
      "type": "string"
    },
    "frameId": {
      "type": "integer",
      "minimum": 0
    },
    "track": {
      "type": "object",
      "required": ["name", "lengthMeters", "widthMeters", "lanes"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "lengthMeters": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "widthMeters": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "index", "centerOffsetMeters", "widthMeters", "speedLimitKph", "waypoints"],
            "properties": {
              "id": { "type": "string" },
              "index": {
                "type": "integer",
                "minimum": 0
              },
              "centerOffsetMeters": { "type": "number" },
              "widthMeters": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "speedLimitKph": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "waypoints": {
                "type": "array",
                "minItems": 4,
                "items": {
                  "type": "object",
                  "required": ["x", "y", "z"],
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "z": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "occupancyGrid": {
      "type": "object",
      "required": ["origin", "cellSizeMeters", "width", "height", "cells"],
      "properties": {
        "origin": {
          "type": "object",
          "required": ["x", "y", "z"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "z": { "type": "number" }
          }
        },
        "cellSizeMeters": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "cells": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "vehicles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "laneId", "lap", "progress", "speedMps", "headingRad", "position", "dimensions", "color"],
        "properties": {
          "id": { "type": "string" },
          "laneId": { "type": "string" },
          "lap": {
            "type": "integer",
            "minimum": 0
          },
          "progress": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "speedMps": {
            "type": "number",
            "minimum": 0
          },
          "headingRad": {
            "type": "number"
          },
          "position": {
            "type": "object",
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          },
          "dimensions": {
            "type": "object",
            "required": ["length", "width", "height"],
            "properties": {
              "length": { "type": "number", "exclusiveMinimum": 0 },
              "width": { "type": "number", "exclusiveMinimum": 0 },
              "height": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "color": { "type": "string" }
        }
      }
    },
    "roadObjects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "position", "rotation", "size", "color"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "position": {
            "type": "object",
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          },
          "rotation": {
            "type": "object",
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          },
          "size": {
            "type": "object",
            "required": ["length", "width", "height"],
            "properties": {
              "length": { "type": "number", "exclusiveMinimum": 0 },
              "width": { "type": "number", "exclusiveMinimum": 0 },
              "height": { "type": "number", "exclusiveMinimum": 0 }
            }
          },
          "color": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
