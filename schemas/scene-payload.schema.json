{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gcp-playground.local/schemas/scene-payload.schema.json",
  "title": "RetroCyberpunkWesternDuelScene",
  "type": "object",
  "required": [
    "schemaVersion",
    "timestamp",
    "sceneId",
    "frameId",
    "environment"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "description": "Unix epoch timestamp in milliseconds encoded as string."
    },
    "sceneId": {
      "type": "string"
    },
    "frameId": {
      "type": "integer",
      "minimum": 0
    },
    "environment": {
      "type": "object",
      "required": ["style", "entities"],
      "properties": {
        "style": {
          "type": "string",
          "enum": ["retro-cyberpunk-western-duel"]
        },
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "position", "rotation"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "position": {
                "type": "object",
                "required": ["x", "y", "z"],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "z": { "type": "number" }
                }
              },
              "rotation": {
                "type": "object",
                "required": ["x", "y", "z"],
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "z": { "type": "number" }
                }
              },
              "scale": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "z": { "type": "number" }
                }
              },
              "material": {
                "type": "object",
                "properties": {
                  "color": { "type": "string" },
                  "emissive": { "type": "string" },
                  "roughness": { "type": "number" },
                  "metalness": { "type": "number" }
                }
              }
            }
          }
        }
      }
    }
  }
}
